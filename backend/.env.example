DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sgs_local
FRONTEND_ORIGIN=http://localhost:3000

# Optional. When set, password login returns requiresGoogleAuth until a valid
# Google ID token for this client is submitted.
GOOGLE_CLIENT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OTP_EXPIRY_MINUTES=5

# Optional column overrides if your SGS tables use different names.
SGS_STUDENT_EMAIL_COLUMN=email
SGS_STUDENT_PHONE_COLUMN=phone
SGS_STUDENT_PASSWORD_COLUMN=password
SGS_TEACHER_EMAIL_COLUMN=email
SGS_TEACHER_PHONE_COLUMN=phone
SGS_TEACHER_PASSWORD_COLUMN=password
SGS_TEACHER_ROLE_COLUMN=role
SGS_PARENT_EMAIL_COLUMN=email
SGS_PARENT_PHONE_COLUMN=phone
SGS_PARENT_PASSWORD_COLUMN=password
SGS_ADMIN_EMAIL_COLUMN=email
SGS_ADMIN_PHONE_COLUMN=phone
SGS_ADMIN_PASSWORD_COLUMN=password
