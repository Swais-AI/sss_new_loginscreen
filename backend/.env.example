DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sss_local
FRONTEND_ORIGIN=http://localhost:3000

# Optional. When set, password login returns requiresGoogleAuth until a valid
# Google ID token for this client is submitted.
GOOGLE_CLIENT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OTP_EXPIRY_MINUTES=5
OTP_DELIVERY_MODE=console

# Optional column overrides if your SSS tables use different names.
SSS_STUDENT_EMAIL_COLUMN=email
SSS_STUDENT_PHONE_COLUMN=phone
SSS_STUDENT_PASSWORD_COLUMN=password
SSS_TEACHER_EMAIL_COLUMN=email
SSS_TEACHER_PHONE_COLUMN=phone
SSS_TEACHER_PASSWORD_COLUMN=password
SSS_TEACHER_ROLE_COLUMN=role
SSS_PARENT_EMAIL_COLUMN=email
SSS_PARENT_PHONE_COLUMN=phone
SSS_PARENT_PASSWORD_COLUMN=password
SSS_ADMIN_EMAIL_COLUMN=email
SSS_ADMIN_PHONE_COLUMN=phone
SSS_ADMIN_PASSWORD_COLUMN=password
